{
  "name": "contextual-ui",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:demo": "bun build demo/main.ts --outdir demo/dist --bundle",
    "demo": "bun build demo/main.ts --outdir demo/dist --bundle && cd demo && python3 -m http.server 8765"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
